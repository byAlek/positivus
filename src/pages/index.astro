---
import { CardIcon1 } from '@/components/icons/card-icon-1'
import { CardIcon2 } from '@/components/icons/card-icon-2'
import { CardIcon3 } from '@/components/icons/card-icon-3'
import { CardIcon4 } from '@/components/icons/card-icon-4'
import { CardIcon5 } from '@/components/icons/card-icon-5'
import { CardIcon6 } from '@/components/icons/card-icon-6'

import { Illustration3 } from '@/components/icons/illustratin-3'
import { Illustration } from '@/components/icons/illustration'
import { Illustration2 } from '@/components/icons/illustration-2'
import { Linkedin } from '@/components/icons/linkedin'
import { Socials } from '@/components/socials'
import { TestimonialsCarousel } from '@/components/testimonials-carousel'
import Accordion from '@/components/ui/accordion.astro'
import { Button } from '@/components/ui/button'
import Card from '@/components/ui/card.astro'
import Heading from '@/components/ui/heading.astro'
import Input from '@/components/ui/input.astro'
import { Link } from '@/components/ui/link'
import Logo from '@/components/ui/logo.astro'
import Textarea from '@/components/ui/textarea.astro'
import { Image } from 'astro:assets'
import Layout from '../layouts/Layout.astro'

const navMap = [
  { href: '#about', label: 'About us' },
  { href: '#services', label: 'Services' },
  { href: '#use-cases', label: 'Use Cases' },
  { href: '#', label: 'Pricing' },
  { href: '#', label: 'Blog' },
  { href: '#contact', label: 'Request a quote' },
]
const accordionItems = [
  {
    label: 'Consultation',
    content:
      'During the initial consultation, we will discuss your business goals and objectives, target audience, and current marketing efforts. This will allow us to understand your needs and tailor our services to best fit your requirements.',
  },
  {
    label: 'Research and Strategy Development',
    content:
      'We conduct thorough research to understand your industry, target audience, and competitors. Based on our findings, we develop a comprehensive strategy tailored to your business needs.',
  },
  {
    label: 'Implementation',
    content:
      'We implement the strategy through various channels including website development, content creation, and digital marketing campaigns. We work closely with you to ensure the implementation aligns with your brand and goals.',
  },
  {
    label: 'Monitoring and Optimization',
    content:
      'We continuously monitor the performance of our strategies and make adjustments as needed to ensure optimal results. This includes tracking key metrics, analyzing data, and making data-driven decisions to improve your marketing efforts.',
  },
  {
    label: 'Reporting and Communication',
    content:
      'We provide regular reports and updates on the progress of our strategies. This includes tracking key metrics, analyzing data, and making data-driven decisions to improve your marketing efforts.',
  },
  {
    label: 'Continual Improvement',
    content:
      'We continuously seek to improve our strategies and services to ensure we are providing the best possible results for our clients. This includes staying up-to-date with the latest marketing trends and technologies, and continuously refining our approach based on data and feedback.',
  },
]
const teamCards = [
  {
    name: 'John Smith',
    position: 'CEO and Founder',
    description:
      '10+ years of experience in digital marketing. Expertise in SEO, PPC, and content strategy',
    image: '/team-picture-1.png',
  },
  {
    name: 'Jane Doe',
    position: 'Director of Operations',
    description:
      '7+ years of experience in project management and team leadership. Strong organizational and communication skills',
    image: '/team-picture-2.png',
  },
  {
    name: 'Michael Brown',
    position: 'Senior SEO Specialist',
    description:
      '5+ years of experience in SEO and content creation. Proficient in keyword research and on-page optimization',
    image: '/team-picture-3.png',
  },
  {
    name: 'Emily Johnson',
    position: 'PPC Manager',
    description:
      '3+ years of experience in paid search advertising. Skilled in campaign management and performance analysis',
    image: '/team-picture-4.png',
  },
  {
    name: 'Brian Williams',
    position: 'Social Media Specialist',
    description:
      '4+ years of experience in social media marketing. Proficient in creating and scheduling content, analyzing metrics, and building engagement',
    image: '/team-picture-5.png',
  },
  {
    name: 'Sarah Kim',
    position: 'Content Creator',
    description:
      '2+ years of experience in writing and editing. Skilled in creating compelling, SEO-optimized content for various industries',
    image: '/team-picture-6.png',
  },
]
const testimonials = [
  {
    name: 'John Smith',
    position: 'CEO and Founder',
    comment:
      '"We have been working with Positivus for the past year and have seen a significant increase in website traffic and leads as a result of their efforts. The team is professional, responsive, and truly cares about the success of our business. We highly recommend Positivus to any company looking to grow their online presence."',
  },
  {
    name: 'Jane Doe',
    position: 'Director of Operations',
    comment:
      '"Positivus has completely transformed the way we manage our projects and internal processes. Their strategic approach and attention to detail helped us streamline operations and improve overall efficiency. The team is incredibly reliable and always goes above and beyond."',
  },
  {
    name: 'Michael Brown',
    position: 'Senior SEO Specialist',
    comment:
      '"Thanks to Positivus, our search rankings and organic traffic have grown consistently month over month. Their deep understanding of SEO and content strategy made a noticeable impact on our visibility. They are a valuable partner for any business looking to scale online."',
  },
  {
    name: 'Emily Johnson',
    position: 'PPC Manager',
    comment:
      '"Working with Positivus has significantly improved our paid advertising performance. Campaigns are better optimized, and we’ve seen a strong increase in ROI. Their data-driven mindset and quick adjustments make all the difference."',
  },
  {
    name: 'Brian Williams',
    position: 'Social Media Specialist',
    comment:
      '"Our social media presence has grown tremendously since partnering with Positivus. Engagement, reach, and overall brand awareness have all improved. The team truly understands how to connect with audiences in a meaningful way."',
  },
  {
    name: 'Sarah Kim',
    position: 'Content Creator',
    comment:
      '"Positivus helped us elevate our content strategy to a whole new level. The quality, consistency, and SEO performance of our content improved significantly. They are creative, strategic, and always aligned with our brand voice."',
  },
]
---

<Layout navMap={navMap}>
  <main class="flex flex-col gap-16 md:gap-24">
    <section class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
      <div class="basis-1/2 space-y-4">
        <h1>Navigating the digital landscape for success</h1>
        <Illustration className="mx-auto size-auto w-full max-w-md md:hidden" />
        <p>
          Our digital marketing agency helps businesses grow and succeed online through a range of
          services including SEO, PPC, social media marketing, and content creation.
        </p>
        <Link href="#" color="secondary-inverted" className="w-full md:w-auto">
          Book a consultation
        </Link>
      </div>
      <Illustration className="hidden size-auto max-w-lg basis-1/2 md:block" />
    </section>
    <div
      class="w-full overflow-hidden mask-r-from-90% mask-l-from-90% brightness-0 select-none dark:invert-100"
    >
      <div class="animate-scroll hover:paused flex h-10 w-max animate-[scroll_50s_linear_infinite]">
        <img src="/Logotypes.svg" class="object-cover" />
        <img src="/Logotypes.svg" class="object-cover" />
      </div>
    </div>
    <section class="space-y-8 lg:space-y-16" id="services">
      <header
        class="flex max-w-4xl flex-col gap-4 text-balance md:flex-row md:items-center md:gap-8"
      >
        <Heading render="h2">Services</Heading>
        <p>
          At our digital marketing agency, we offer a range of services to help businesses grow and
          succeed online. These services include:
        </p>
      </header>
      <ul
        class:list={[
          'grid gap-8 lg:grid-cols-2 lg:gap-16',
          '*:mx-auto *:grid *:max-w-xl *:grid-cols-2 *:place-items-start',
          '[&_a]:mt-auto lg:[&_a]:order-last [&_h3]:col-span-2 [&_h3]:whitespace-nowrap lg:[&_h3]:col-span-1 [&_svg]:ml-auto [&_svg]:size-auto [&_svg]:w-full [&_svg]:max-w-64 lg:[&_svg]:row-span-2',
        ]}
      >
        <Card render="li" color="muted">
          <h3>
            <Heading render="span">Search engine</Heading>
            <br />
            <Heading render="span">optimization</Heading>
          </h3>
          <Link href="#" variant="with-arrow-2" color="secondary" iconColor="primary-inverted">
            Learn more
          </Link>
          <CardIcon1 className="text-muted-foreground" />
        </Card>
        <Card render="li" color="primary">
          <h3>
            <Heading render="span" color="light">Pay-per-click</Heading>
            <br />
            <Heading render="span" color="light">advertising</Heading>
          </h3>
          <Link
            href="#"
            variant="with-arrow-2"
            color="primary-inverted"
            iconColor="primary-inverted"
          >
            Learn more
          </Link>
          <CardIcon2 />
        </Card>
        <Card render="li" color="secondary">
          <h3>
            <Heading render="span" color="secondary-inverted">Social Media</Heading>
            <br />
            <Heading render="span" color="secondary-inverted">Marketing</Heading>
          </h3>
          <Link
            href="#"
            variant="with-arrow-2"
            color="secondary-inverted"
            iconColor="secondary-inverted"
          >
            Learn more
          </Link>
          <CardIcon3 />
        </Card>
        <Card render="li" color="muted">
          <h3>
            <Heading render="span">Email</Heading>
            <br />
            <Heading render="span">Marketing</Heading>
          </h3>
          <Link href="#" variant="with-arrow-2" color="secondary" iconColor="primary-inverted">
            Learn more
          </Link>
          <CardIcon4 className="text-muted-foreground" />
        </Card>
        <Card render="li" color="primary">
          <h3>
            <Heading render="span" color="light">Content</Heading>
            <br />
            <Heading render="span" color="light">Creation</Heading>
          </h3>
          <Link
            href="#"
            variant="with-arrow-2"
            color="primary-inverted"
            iconColor="primary-inverted"
          >
            Learn more
          </Link>
          <CardIcon5 />
        </Card>
        <Card render="li" color="secondary">
          <h3>
            <Heading render="span" color="secondary-inverted">Analytics and</Heading>
            <br />
            <Heading render="span" color="secondary-inverted">Tracking</Heading>
          </h3>
          <Link
            href="#"
            variant="with-arrow-2"
            color="secondary-inverted"
            iconColor="secondary-inverted"
          >
            Learn more
          </Link>
          <CardIcon6 />
        </Card>
      </ul>
    </section>
    <section>
      <Card color="muted" className="grid gap-8 border-none shadow-none md:grid-cols-2">
        <h2>Let's make things happen</h2>
        <div class="relative row-span-3 hidden md:block">
          <Illustration2
            className="absolute top-1/2 left-1/2 h-auto max-h-100 w-full -translate-x-1/2 -translate-y-1/2"
          />
        </div>
        <p>
          Contact us today to learn more about how our digital marketing services can help your
          business grow and succeed online.
        </p>
        <Link href="#" color="secondary-inverted">Get your free proposal</Link>
      </Card>
    </section>
    <section class="space-y-8 lg:space-y-16" id="use-cases">
      <header
        class="flex max-w-4xl flex-col gap-4 text-balance md:flex-row md:items-center md:gap-8"
      >
        <Heading render="h2">Case Studies</Heading>
        <p>
          Explore Real-Life Examples of Our Proven Digital Marketing Success through Our Case
          Studies
        </p>
      </header>
      <Card
        render="ul"
        color="secondary"
        className="dark:[&_a]:text-secondary-foreground *:before:bg-secondary-foreground/70 *:after:bg-secondary-foreground/70 flex flex-col gap-16 *:relative *:before:absolute *:before:inset-x-0 *:before:-bottom-8 *:before:h-px *:after:absolute *:after:inset-y-0 *:after:-right-16 *:after:hidden *:after:w-px *:last:before:hidden *:last:after:hidden xl:flex-row xl:gap-32 *:xl:before:hidden *:xl:after:block [&_a]:-ml-2 [&_article]:space-y-4 [&_p]:text-pretty"
      >
        <li>
          <article>
            <h3 class="sr-only">Local Restaurant PPC Campaign</h3>
            <p>
              For a local restaurant, we implemented a targeted PPC campaign that resulted in a 50%
              increase in website traffic and a 25% increase in sales.
            </p>
            <Link href="#" variant="with-arrow" color="primary">Learn more</Link>
          </article>
        </li>
        <li>
          <article>
            <h3 class="sr-only">B2B Software SEO Strategy</h3>
            <p>
              For a B2B software company, we developed an SEO strategy that resulted in a first page
              ranking for key keywords and a 200% increase in organic traffic.
            </p>
            <Link href="#" variant="with-arrow" color="primary">Learn more</Link>
          </article>
        </li>
        <li>
          <article>
            <h3 class="sr-only">National Retail Chain Social Media Campaign</h3>
            <p>
              For a national retail chain, we created a social media marketing campaign that
              increased followers by 25% and generated a 20% increase in online sales.
            </p>
            <Link href="#" variant="with-arrow" color="primary">Learn more</Link>
          </article>
        </li>
      </Card>
    </section>
    <section class="space-y-8 lg:space-y-16">
      <header
        class="flex max-w-4xl flex-col gap-4 text-balance md:flex-row md:items-center md:gap-8"
      >
        <Heading render="h2">Our Working Process</Heading>
        <p>Step-by-Step Guide to Achieving Your Business Goals</p>
      </header>
      <div class="space-y-8">
        {
          accordionItems.map(({ label, content }, i) => (
            <Accordion open={i === 0}>
              <span slot="label" class="text-h3 md:text-h2 flex items-center gap-4 md:gap-8">
                <span class="text-h2 md:text-h1">{i + 1}</span>
                {label}
              </span>
              <p>{content}</p>
            </Accordion>
          ))
        }
      </div>
    </section>
    <section class="space-y-8 lg:space-y-16" id="about">
      <header
        class="flex max-w-4xl flex-col gap-4 text-balance md:flex-row md:items-center md:gap-8"
      >
        <Heading render="h2">Team</Heading>
        <p>
          Meet the skilled and experienced team behind our successful digital marketing strategies
        </p>
      </header>
      <ul class="grid gap-8 sm:grid-cols-2 xl:grid-cols-3">
        {
          teamCards.map(({ name, position, description, image }, i) => (
            <Card render="li" color="muted" className="p-8!">
              <div class="flex gap-2">
                <Image
                  width="96"
                  height="96"
                  src={image}
                  alt={name}
                  class="aspect-square h-full max-h-24 object-contain"
                />
                <div class="flex flex-1 flex-col">
                  <Linkedin className="fill-primary text-primary-foreground ml-auto mb-auto size-8" />
                  <h3>{name}</h3>
                  <p>{position}</p>
                </div>
              </div>
              <p class="border-foreground/50 mt-4 border-t pt-4 text-base">{description}</p>
            </Card>
          ))
        }
      </ul>
      <Link href="#" color="secondary-inverted" className="ml-auto flex w-fit">See all team</Link>
    </section>
    <section class="space-y-8 lg:space-y-16">
      <header
        class="flex max-w-4xl flex-col gap-4 text-balance md:flex-row md:items-center md:gap-8"
      >
        <Heading render="h2">Testimonials</Heading>
        <p>
          Hear from Our Satisfied Clients: Read Our Testimonials to Learn More about Our Digital
          Marketing Services.
        </p>
      </header>
      <Card color="secondary" className="px-0! shadow-none">
        <TestimonialsCarousel client:load data={testimonials} />
      </Card>
    </section>
    <section class="space-y-8 lg:space-y-16" id="contact">
      <header
        class="flex max-w-4xl flex-col gap-4 text-balance md:flex-row md:items-center md:gap-8"
      >
        <Heading render="h2">Connect Us</Heading>
        <p>Connect with Us: Let's Discuss Your Digital Marketing Needs</p>
      </header>
      <Card color="muted" className="relative grid shadow-none md:grid-cols-2">
        <form class="grid gap-4 md:gap-8 [&>label]:flex [&>label]:flex-col [&>label]:gap-1">
          <div
            class="*:rounded-layout *:ring-foreground flex gap-4 *:flex *:items-center *:p-2 *:transition-shadow *:*:last:ml-2 *:has-[input:focus-visible]:ring-4 md:gap-8"
          >
            <label>
              <Input
                type="radio"
                name="contact-type"
                value="say-hi"
                class="peer size-0 opacity-0"
                checked
              />
              <span
                class="peer-checked:bg-primary bg-muted border-muted ring-border/50 peer-checked:ring-border size-4 rounded-full border-4 p-1 ring-1 transition-all"
              ></span>
              <span class="text-foreground/70 peer-checked:text-foreground">Say Hi</span>
            </label>
            <label>
              <Input
                type="radio"
                name="contact-type"
                value="get-quote"
                class="peer size-0 opacity-0"
              />
              <span
                class="peer-checked:bg-primary bg-muted border-muted ring-border/50 peer-checked:ring-border size-4 rounded-full border-4 p-1 ring-1 transition-all"
              ></span>
              <span class="text-foreground/70 peer-checked:text-foreground">Get a Quote</span>
            </label>
          </div>
          <label>
            <span>Name</span>
            <Input type="text" placeholder="Name" />
          </label>
          <label>
            <span>Email*</span>
            <Input type="email" placeholder="Email" />
          </label>
          <label>
            <span>Message*</span>
            <Textarea placeholder="Message" />
          </label>
          <Button type="button" color="secondary-inverted">Send Message</Button>
        </form>
        <Illustration3
          className="fill-primary absolute top-1/2 right-0 hidden size-auto max-h-9/10 -translate-y-1/2 md:block"
        />
      </Card>
    </section>
    <footer class="space-y-8 lg:space-y-16">
      <Card color="secondary" className="space-y-8 rounded-b-none shadow-none">
        <header class="py-4">
          <nav class="flex flex-wrap items-center justify-between lg:flex-nowrap">
            <Logo class="text-secondary-foreground" />
            <Socials />
            <div
              class="mx-auto flex w-fit basis-full flex-wrap items-center justify-center gap-x-4 gap-y-1 md:basis-auto"
            >
              {
                navMap.map(({ href, label }) => (
                  <a
                    href={href}
                    class="focus-ring p-2 whitespace-nowrap underline transition-shadow"
                  >
                    {label}
                  </a>
                ))
              }
            </div>
          </nav>
        </header>

        <div class="grid items-center gap-y-4 lg:grid-cols-2">
          <div class="flex max-w-sm flex-col gap-4">
            <Heading render="h2">Contact us:</Heading>
            <p>Email: info@positivus.com</p>
            <p>Phone: +1 (555) 123-4567</p>
            <p>Address: 1234 Main St Moonstone City, Stardust State 12345</p>
          </div>
          <Card className="bg-muted/10 text-secondary-foreground grid gap-8 shadow-none">
            <Input type="email" placeholder="Email" />
            <Button color="primary-inverted">Subscribe to news</Button>
          </Card>
        </div>
        <div
          class="text-secondary-foreground/70 flew-wrap border-secondary-foreground/30 mt-8 flex items-center gap-4 border-t pt-8"
        >
          <p>© 2023 Positivus. All Rights Reserved.</p>
          <a href="#" class="focus-ring rounded-layout p-1 underline transition-shadow">
            Privacy Policy
          </a>
        </div>
      </Card>
    </footer>
  </main>
</Layout>

<style>
  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
