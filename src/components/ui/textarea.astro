---
import { cn } from '@/lib/utils'

type Props = astroHTML.JSX.TextareaHTMLAttributes

const { class: className, ...rest } = Astro.props
---

<textarea
  class={cn(
    'focus-ring rounded-layout focus-visible:border-border/30 text-foreground bg-background/70 placeholder:text-foreground/70 field-sizing-content max-h-80 min-h-40 resize-none border p-2 transition-all',
    className
  )}
  {...rest}></textarea>
