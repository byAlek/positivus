---
import { cn } from '@/lib/utils'

type Props = astroHTML.JSX.InputHTMLAttributes

const { class: className, ...rest } = Astro.props
---

<input
  class={cn(
    'focus-ring focus-visible:border-border/30 rounded-layout text-foreground bg-background/70 placeholder:text-foreground/70 border p-2 transition-all',
    className
  )}
  {...rest}
/>
