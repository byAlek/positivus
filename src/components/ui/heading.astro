---
import { cn } from '@/lib/utils'
import { cva, type VariantProps } from 'class-variance-authority'

const headingVariants = cva(
  'rounded-layout inline-flex w-fit items-center justify-center gap-2 px-3 py-1 whitespace-nowrap',
  {
    variants: {
      color: {
        primary: 'bg-primary text-primary-foreground',
        secondary: 'bg-secondary text-secondary-foreground',
        'secondary-inverted': 'bg-secondary-foreground text-secondary',
        light: 'bg-white text-black',
        dark: 'bg-black text-white',
      },
    },
    defaultVariants: {
      color: 'primary',
    },
  }
)

type Props = {
  render: keyof astroHTML.JSX.DefinedIntrinsicElements
  className?: string
} & astroHTML.JSX.HTMLAttributes &
  VariantProps<typeof headingVariants>

const { className, render: Render, color, ...props } = Astro.props as Props
---

<Render class={cn(headingVariants({ color, className }))} {...props}>
  <slot>Heading</slot>
</Render>
